#!/bin/bash

# ==========================================================
# EXPERIMENT 002: COMPLEMENTARY HYBRID LOSS VS BASELINE
# TARGET: COMPLEX CLASSES (CABLE & TRANSISTOR)
# ==========================================================

PROJECT_ROOT="/home/ptitdemo/TVQH_TLU/Research Project 2/Ours"
DATA_PATH="/home/ptitdemo/TVQH_TLU/Research Project 2/Dataset/MVTec AD"
EPOCHS=50
RUN_NAME="exp002_$(date +%Hh%M_%d-%m-%Y)"
CLASSES=("cable" "transistor")

# Activate environment
source "$PROJECT_ROOT/venv/bin/activate"

cd "$PROJECT_ROOT" || exit

echo "Starting Experiment 002..."
echo "Run Name: $RUN_NAME"
echo "Target Classes: ${CLASSES[*]}"
echo "=========================================================="

for CLASS in "${CLASSES[@]}"; do
    echo "Processing Class: $CLASS"

    # 1. Baseline (Reconstruction Only)
    echo "Running Baseline for $CLASS..."
    python foundad/main.py mode=train app=train_dinov3 \
        data.data_name=$CLASS \
        data.data_path="$DATA_PATH" \
        data.train_root="$DATA_PATH/$CLASS" \
        data.test_root="$DATA_PATH" \
        optimization.epochs=$EPOCHS \
        app.meta.feat_normed=true \
        app.meta.loss_config.lam1=0 \
        app.meta.loss_config.lam3=0 \
        app.meta.loss_config.lam4=0 \
        dist.master_port=40212 \
        +run_name="$RUN_NAME" \
        +variant="Baseline" &

    # 2. Ours (Complementary Hybrid Loss v2)
    echo "Running Ours v2 for $CLASS..."
    python foundad/main.py mode=train app=train_dinov3 \
        data.data_name=$CLASS \
        data.data_path="$DATA_PATH" \
        data.train_root="$DATA_PATH/$CLASS" \
        data.test_root="$DATA_PATH" \
        optimization.epochs=$EPOCHS \
        app.meta.feat_normed=true \
        app.meta.loss_config.lam1=0.1 \
        app.meta.loss_config.lam3=0.5 \
        app.meta.loss_config.lam4=0.1 \
        dist.master_port=40213 \
        +run_name="$RUN_NAME" \
        +variant="Ours" &

    wait
    echo "Done Class: $CLASS"
done

echo "=========================================================="
echo "EXPERIMENT 002 COMPLETED!"
echo "Logs saved to: logs/$RUN_NAME"
echo "=========================================================="
